# Target host (Ubuntu 24.04). Remote mode uses it for SSH and DNS binding
# checks; local mode can also use it as the expected public host for
# KODEX_PRODUCTION_DOMAIN.
TARGET_HOST=""
TARGET_PORT="22"
TARGET_ROOT_USER="root"
TARGET_ROOT_SSH_KEY="${HOME}/.ssh/id_rsa"
# Optional: if TARGET_ROOT_USER is not root, bootstrap files are copied to this directory
# and root steps are executed through sudo.
KODEX_REMOTE_BOOTSTRAP_DIR=""

# New operator user created on target host
OPERATOR_USER="codex"
OPERATOR_SSH_PUBKEY_PATH="${HOME}/.ssh/id_rsa.pub"

# Platform repository with kodex source (owner/name).
# Bootstrap config and secrets are stored in Kubernetes, not in GitHub variables/secrets.
KODEX_GITHUB_REPO=""
# Optional first project repository (owner/name) for additional webhook + labels setup.
# Bootstrap always configures webhook + labels in KODEX_GITHUB_REPO.
# If empty, only KODEX_GITHUB_REPO is configured (dogfooding mode).
KODEX_FIRST_PROJECT_GITHUB_REPO=""

# External credentials (optional in file; if empty script will ask interactively)
# Required: fine-grained GitHub token used by bootstrap/Kaniko and
# stored in Kubernetes runtime secrets for provider/project management paths.
# Minimum permissions: repository access required by platform management paths + administration (read/write for webhook/labels in platform repo and optional first project repo).
KODEX_GITHUB_PAT=""
# OpenAI API key for codex-cli API-key auth (optional).
# If empty, Codex will use ChatGPT device auth on first agent run (instructions appear in run logs).
KODEX_OPENAI_API_KEY=""
# Dedicated git transport token for agent-run pods.
KODEX_GIT_BOT_TOKEN=""
KODEX_GIT_BOT_USERNAME="codex-bot"
KODEX_GIT_BOT_MAIL="codex-bot@kodex.local"
# Project DB admin profile used by MCP `database.lifecycle`.
# If any value is empty, bootstrap derives defaults and stores them in Kubernetes secrets:
# - HOST: postgres
# - PORT: 5432
# - USER/PASSWORD: KODEX_POSTGRES_USER / KODEX_POSTGRES_PASSWORD
# - SSLMODE: disable
# - DATABASE: postgres
KODEX_PROJECT_DB_ADMIN_HOST=""
KODEX_PROJECT_DB_ADMIN_PORT=""
KODEX_PROJECT_DB_ADMIN_USER=""
KODEX_PROJECT_DB_ADMIN_PASSWORD=""
KODEX_PROJECT_DB_ADMIN_SSLMODE=""
KODEX_PROJECT_DB_ADMIN_DATABASE=""
# Optional comma-separated allowlist for MCP `database.lifecycle` environment scoping.
# Empty value means app defaults are used (dev,production,prod).
KODEX_PROJECT_DB_LIFECYCLE_ALLOWED_ENVS=""
KODEX_CONTEXT7_API_KEY=""

# Environment-scoped overrides (optional).
#
# For AI slots the platform reads secrets from the shared Kubernetes secret:
# - kodex-runtime-ai (production namespace)
#
# Override rule:
# - Base key: KODEX_<NAME>
# - AI override key: KODEX_AI_<NAME>
# - Production override key: KODEX_PRODUCTION_<NAME>
# - Additional pattern mode: KODEX_<NAME>_AI (see spec.secretResolution in services.yaml).
#
# Example: to use a different OpenAI key in AI slots set KODEX_AI_OPENAI_API_KEY.
KODEX_AI_OPENAI_API_KEY=""
KODEX_AI_CONTEXT7_API_KEY=""
KODEX_AI_GITHUB_PAT=""
KODEX_AI_GIT_BOT_TOKEN=""
KODEX_GITHUB_OAUTH_CLIENT_ID_AI=""
KODEX_GITHUB_OAUTH_CLIENT_SECRET_AI=""
KODEX_PRODUCTION_GITHUB_OAUTH_CLIENT_ID=""
KODEX_PRODUCTION_GITHUB_OAUTH_CLIENT_SECRET=""

# Staff auth (platform SSO/OIDC + short-lived JWT).
#
# Baseline IdP: Keycloak. GitHub/GitLab are configured as external identity providers.
# Slots use the shared SSO/gateway endpoints through nginx auth-url/auth-signin
# and do not require a separate GitHub/GitLab OAuth app per slot.
#
# Public base URL is used for SSO redirect URL generation and must match your domain.
KODEX_PUBLIC_BASE_URL="https://platform.example.test"
# Optional: centralized SSO endpoints used by slot ingresses.
# Empty values are auto-derived from KODEX_PRODUCTION_DOMAIN:
# - https://<KODEX_PRODUCTION_DOMAIN>/oauth2/auth
# - https://<KODEX_PRODUCTION_DOMAIN>/oauth2/start?rd=$scheme://$host$request_uri
KODEX_SHARED_OAUTH2_PROXY_AUTH_URL=""
KODEX_SHARED_OAUTH2_PROXY_SIGNIN_URL=""
# Optional: cookie domain for shared SSO gateway session.
# Empty value is auto-derived as ".<KODEX_PRODUCTION_DOMAIN>".
KODEX_OAUTH2_PROXY_COOKIE_DOMAIN=""
# Registration is disabled; first login is allowed only for pre-approved email.
# Owner email becomes a platform admin and can add other users later.
KODEX_BOOTSTRAP_OWNER_EMAIL="owner@example.com"
# Optional: comma-separated list of additional staff emails to pre-provision into DB on startup.
# This avoids {"code":"forbidden","message":"email is not allowed"} on first login.
KODEX_BOOTSTRAP_ALLOWED_EMAILS=""
# Optional: comma-separated list of additional platform admins (owners).
# These emails are created/updated in DB with is_platform_admin=true on startup.
KODEX_BOOTSTRAP_PLATFORM_ADMIN_EMAILS=""
KODEX_GITHUB_OAUTH_CLIENT_ID=""
KODEX_GITHUB_OAUTH_CLIENT_SECRET=""
# Optional: if empty, bootstrap generates a random value.
KODEX_JWT_SIGNING_KEY=""
KODEX_MCP_TOKEN_SIGNING_KEY=""
# Short-lived JWT TTL (e.g. 15m, 30m). Stored in runtime secret as plain text.
KODEX_JWT_TTL="15m"
KODEX_MCP_TOKEN_TTL="24h"
KODEX_RUN_HEAVY_FIELDS_RETENTION_DAYS="7"
KODEX_RUN_AGENT_LOGS_RETENTION_DAYS="7"
# access-manager internal gRPC boundary.
# Optional: if empty, bootstrap generates a random shared token and stores it in runtime secret.
KODEX_ACCESS_MANAGER_GRPC_AUTH_TOKEN=""
KODEX_ACCESS_MANAGER_GRPC_AUTH_REQUIRED="true"
KODEX_ACCESS_MANAGER_GRPC_MAX_IN_FLIGHT="128"
KODEX_ACCESS_MANAGER_GRPC_MAX_CONCURRENT_STREAMS="128"
KODEX_ACCESS_MANAGER_GRPC_UNARY_TIMEOUT="30s"
KODEX_ACCESS_MANAGER_GRPC_KEEPALIVE_TIME="2m"
KODEX_ACCESS_MANAGER_GRPC_KEEPALIVE_TIMEOUT="20s"
KODEX_ACCESS_MANAGER_GRPC_KEEPALIVE_MIN_TIME="30s"
KODEX_ACCESS_MANAGER_GRPC_PERMIT_WITHOUT_STREAM="false"
KODEX_ACCESS_MANAGER_GRPC_MAX_RECV_MESSAGE_BYTES="4194304"
KODEX_ACCESS_MANAGER_GRPC_MAX_SEND_MESSAGE_BYTES="4194304"
KODEX_ACCESS_MANAGER_REPLICAS="2"
KODEX_ACCESS_MANAGER_CPU_REQUEST="100m"
KODEX_ACCESS_MANAGER_MEMORY_REQUEST="128Mi"
KODEX_ACCESS_MANAGER_CPU_LIMIT="2"
KODEX_ACCESS_MANAGER_MEMORY_LIMIT="512Mi"
KODEX_ACCESS_MANAGER_OUTBOX_DISPATCH_ENABLED="true"
KODEX_ACCESS_MANAGER_OUTBOX_PUBLISHER_KIND="postgres-event-log"
KODEX_ACCESS_MANAGER_OUTBOX_EVENT_LOG_SOURCE="access-manager"
KODEX_ACCESS_MANAGER_OUTBOX_BATCH_SIZE="100"
KODEX_ACCESS_MANAGER_OUTBOX_POLL_INTERVAL="1s"
KODEX_ACCESS_MANAGER_OUTBOX_LOCK_TTL="30s"
KODEX_ACCESS_MANAGER_OUTBOX_PUBLISH_TIMEOUT="10s"
KODEX_ACCESS_MANAGER_OUTBOX_LEASE_SAFETY_MARGIN="5s"
KODEX_ACCESS_MANAGER_OUTBOX_RETRY_INITIAL_DELAY="1s"
KODEX_ACCESS_MANAGER_OUTBOX_RETRY_MAX_DELAY="1m"
KODEX_ACCESS_MANAGER_OUTBOX_FAILURE_MESSAGE_LIMIT="512"
# access-manager PostgreSQL boundaries.
# If DSN values are empty, bootstrap derives them from KODEX_POSTGRES_* and database names.
KODEX_ACCESS_MANAGER_DATABASE_NAME="kodex_access_manager"
KODEX_PLATFORM_EVENT_LOG_DATABASE_NAME="kodex_platform_event_log"
KODEX_ACCESS_MANAGER_DATABASE_DSN=""
KODEX_PLATFORM_EVENT_LOG_DATABASE_DSN=""
KODEX_ACCESS_MANAGER_EVENT_LOG_DATABASE_DSN=""
KODEX_ACCESS_MANAGER_DATABASE_MAX_CONNS="8"
