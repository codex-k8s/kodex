KODEX_RUNTIME_MANAGER_GRPC_MAX_CONCURRENT_STREAMS="128"
KODEX_RUNTIME_MANAGER_GRPC_UNARY_TIMEOUT="30s"
KODEX_RUNTIME_MANAGER_GRPC_KEEPALIVE_TIME="2m"
KODEX_RUNTIME_MANAGER_GRPC_KEEPALIVE_TIMEOUT="20s"
KODEX_RUNTIME_MANAGER_GRPC_KEEPALIVE_MIN_TIME="30s"
KODEX_RUNTIME_MANAGER_GRPC_PERMIT_WITHOUT_STREAM="false"
KODEX_RUNTIME_MANAGER_GRPC_MAX_RECV_MESSAGE_BYTES="4194304"
KODEX_RUNTIME_MANAGER_GRPC_MAX_SEND_MESSAGE_BYTES="4194304"
KODEX_RUNTIME_MANAGER_REPLICAS="2"
KODEX_RUNTIME_MANAGER_CPU_REQUEST="100m"
KODEX_RUNTIME_MANAGER_MEMORY_REQUEST="128Mi"
KODEX_RUNTIME_MANAGER_CPU_LIMIT="2"
KODEX_RUNTIME_MANAGER_MEMORY_LIMIT="512Mi"
KODEX_RUNTIME_MANAGER_ACCESS_CHECK_ENABLED="true"
KODEX_RUNTIME_MANAGER_ACCESS_MANAGER_GRPC_ADDR="access-manager:9090"
KODEX_RUNTIME_MANAGER_ACCESS_MANAGER_GRPC_AUTH_TOKEN=""
KODEX_RUNTIME_MANAGER_ACCESS_MANAGER_CHECK_TIMEOUT="3s"
KODEX_RUNTIME_MANAGER_FLEET_MANAGER_GRPC_ADDR="fleet-manager:9090"
# Optional: if empty, bootstrap reuses KODEX_FLEET_MANAGER_GRPC_AUTH_TOKEN.
KODEX_RUNTIME_MANAGER_FLEET_MANAGER_GRPC_AUTH_TOKEN=""
KODEX_RUNTIME_MANAGER_FLEET_MANAGER_RESOLVE_TIMEOUT="5s"
KODEX_RUNTIME_MANAGER_OUTBOX_DISPATCH_ENABLED="true"
KODEX_RUNTIME_MANAGER_OUTBOX_PUBLISHER_KIND="postgres-event-log"
KODEX_RUNTIME_MANAGER_OUTBOX_EVENT_LOG_SOURCE="runtime-manager"
KODEX_RUNTIME_MANAGER_OUTBOX_BATCH_SIZE="100"
KODEX_RUNTIME_MANAGER_OUTBOX_POLL_INTERVAL="1s"
KODEX_RUNTIME_MANAGER_OUTBOX_LOCK_TTL="30s"
KODEX_RUNTIME_MANAGER_OUTBOX_PUBLISH_TIMEOUT="10s"
KODEX_RUNTIME_MANAGER_OUTBOX_LEASE_SAFETY_MARGIN="5s"
KODEX_RUNTIME_MANAGER_OUTBOX_RETRY_INITIAL_DELAY="1s"
KODEX_RUNTIME_MANAGER_OUTBOX_RETRY_MAX_DELAY="1m"
KODEX_RUNTIME_MANAGER_OUTBOX_FAILURE_MESSAGE_LIMIT="512"
# runtime-manager slot lifecycle defaults.
KODEX_RUNTIME_MANAGER_SLOT_DEFAULT_FLEET_SCOPE_ID="00000000-0000-0000-0000-000000000001"
KODEX_RUNTIME_MANAGER_SLOT_DEFAULT_CLUSTER_ID="00000000-0000-0000-0000-000000000002"
KODEX_RUNTIME_MANAGER_SLOT_NAMESPACE_PREFIX="kodex-rt"
KODEX_RUNTIME_MANAGER_SLOT_DEFAULT_LEASE_TTL="30m"
# runtime-manager PostgreSQL boundary.
# If DSN values are empty, bootstrap derives them from KODEX_POSTGRES_* and database names.
KODEX_RUNTIME_MANAGER_DATABASE_NAME="kodex_runtime_manager"
KODEX_RUNTIME_MANAGER_DATABASE_DSN=""
KODEX_RUNTIME_MANAGER_EVENT_LOG_DATABASE_DSN=""
KODEX_RUNTIME_MANAGER_DATABASE_MAX_CONNS="8"
KODEX_RUNTIME_MANAGER_DATABASE_MIN_CONNS="1"
KODEX_RUNTIME_MANAGER_EVENT_LOG_DATABASE_MAX_CONNS="4"
KODEX_RUNTIME_MANAGER_EVENT_LOG_DATABASE_MIN_CONNS="0"
# Optional: if empty, bootstrap generates a random value.
# Used for validating GitHub webhook signatures (X-Hub-Signature-256).
KODEX_GITHUB_WEBHOOK_SECRET=""
# Optional override for repository webhook endpoint.
KODEX_GITHUB_WEBHOOK_URL=""
# Comma-separated GitHub webhook events.
KODEX_GITHUB_WEBHOOK_EVENTS="push,pull_request,issues,issue_comment,pull_request_review,pull_request_review_comment"

# Canonical label catalog used for GitHub labels and platform env/config rendering.
# Active in S3 Day1+: full run:* stage catalog + state:* + need:* labels.
KODEX_RUN_INTAKE_LABEL="run:intake"
KODEX_RUN_INTAKE_REVISE_LABEL="run:intake:revise"
KODEX_RUN_VISION_LABEL="run:vision"
KODEX_RUN_VISION_REVISE_LABEL="run:vision:revise"
KODEX_RUN_PRD_LABEL="run:prd"
KODEX_RUN_PRD_REVISE_LABEL="run:prd:revise"
KODEX_RUN_ARCH_LABEL="run:arch"
KODEX_RUN_ARCH_REVISE_LABEL="run:arch:revise"
KODEX_RUN_DESIGN_LABEL="run:design"
KODEX_RUN_DESIGN_REVISE_LABEL="run:design:revise"
KODEX_RUN_PLAN_LABEL="run:plan"
KODEX_RUN_PLAN_REVISE_LABEL="run:plan:revise"
KODEX_RUN_DEV_LABEL="run:dev"
KODEX_RUN_DEV_REVISE_LABEL="run:dev:revise"
KODEX_RUN_DEBUG_LABEL="run:debug"
KODEX_RUN_DOC_AUDIT_LABEL="run:doc-audit"
KODEX_RUN_QA_LABEL="run:qa"
KODEX_RUN_RELEASE_LABEL="run:release"
KODEX_RUN_POSTDEPLOY_LABEL="run:postdeploy"
KODEX_RUN_OPS_LABEL="run:ops"
KODEX_RUN_SELF_IMPROVE_LABEL="run:self-improve"
KODEX_RUN_RETHINK_LABEL="run:rethink"
KODEX_MODE_DISCUSSION_LABEL="mode:discussion"
KODEX_STATE_BLOCKED_LABEL="state:blocked"
KODEX_STATE_IN_REVIEW_LABEL="state:in-review"
KODEX_STATE_APPROVED_LABEL="state:approved"
KODEX_STATE_SUPERSEDED_LABEL="state:superseded"
KODEX_STATE_ABANDONED_LABEL="state:abandoned"
KODEX_NEED_INPUT_LABEL="need:input"
KODEX_NEED_PM_LABEL="need:pm"
KODEX_NEED_SA_LABEL="need:sa"
KODEX_NEED_QA_LABEL="need:qa"
KODEX_NEED_SRE_LABEL="need:sre"
KODEX_NEED_EM_LABEL="need:em"
KODEX_NEED_KM_LABEL="need:km"
KODEX_NEED_REVIEWER_LABEL="need:reviewer"

# Configuration labels (model/reasoning profile for run:dev and run:dev:revise).
KODEX_AI_MODEL_GPT_5_4_LABEL="[ai-model-gpt-5.4]"
KODEX_AI_MODEL_GPT_5_3_CODEX_LABEL="[ai-model-gpt-5.3-codex]"
KODEX_AI_MODEL_GPT_5_3_CODEX_SPARK_LABEL="[ai-model-gpt-5.3-codex-spark]"
KODEX_AI_MODEL_GPT_5_2_CODEX_LABEL="[ai-model-gpt-5.2-codex]"
KODEX_AI_MODEL_GPT_5_1_CODEX_MAX_LABEL="[ai-model-gpt-5.1-codex-max]"
KODEX_AI_MODEL_GPT_5_2_LABEL="[ai-model-gpt-5.2]"
KODEX_AI_MODEL_GPT_5_1_CODEX_MINI_LABEL="[ai-model-gpt-5.1-codex-mini]"
KODEX_AI_REASONING_LOW_LABEL="[ai-reasoning-low]"
KODEX_AI_REASONING_MEDIUM_LABEL="[ai-reasoning-medium]"
KODEX_AI_REASONING_HIGH_LABEL="[ai-reasoning-high]"
KODEX_AI_REASONING_EXTRA_HIGH_LABEL="[ai-reasoning-extra-high]"

# Production settings
KODEX_PRODUCTION_NAMESPACE="kodex-prod"
# Required: must resolve to TARGET_HOST, or to the current host in local mode
# when TARGET_HOST is empty, before bootstrap starts.
KODEX_PRODUCTION_DOMAIN="platform.example.test"
KODEX_AI_DOMAIN="ai.platform.example.test"
# Required for Let's Encrypt account registration.
KODEX_LETSENCRYPT_EMAIL="ops@example.com"
KODEX_LETSENCRYPT_SERVER="https://acme-v02.api.letsencrypt.org/directory"

# Internal registry (no auth by design for MVP).
# Security model for production: registry listens on node loopback (127.0.0.1) only.
# This profile is intended for single-node production.
KODEX_INTERNAL_REGISTRY_SERVICE="kodex-registry"
KODEX_INTERNAL_REGISTRY_PORT="5000"
KODEX_INTERNAL_REGISTRY_STORAGE_SIZE="20Gi"
KODEX_INTERNAL_REGISTRY_HOST="127.0.0.1:5000"
KODEX_ACCESS_MANAGER_INTERNAL_IMAGE_REPOSITORY="kodex/access-manager"
KODEX_ACCESS_MANAGER_MIGRATIONS_INTERNAL_IMAGE_REPOSITORY="kodex/access-manager-migrations"
KODEX_PROJECT_CATALOG_INTERNAL_IMAGE_REPOSITORY="kodex/project-catalog"
KODEX_PROJECT_CATALOG_MIGRATIONS_INTERNAL_IMAGE_REPOSITORY="kodex/project-catalog-migrations"
KODEX_PACKAGE_HUB_INTERNAL_IMAGE_REPOSITORY="kodex/package-hub"
KODEX_PACKAGE_HUB_MIGRATIONS_INTERNAL_IMAGE_REPOSITORY="kodex/package-hub-migrations"
KODEX_PROVIDER_HUB_INTERNAL_IMAGE_REPOSITORY="kodex/provider-hub"
KODEX_PROVIDER_HUB_MIGRATIONS_INTERNAL_IMAGE_REPOSITORY="kodex/provider-hub-migrations"
KODEX_INTEGRATION_GATEWAY_INTERNAL_IMAGE_REPOSITORY="kodex/integration-gateway"
KODEX_CODEX_HOOK_INGRESS_INTERNAL_IMAGE_REPOSITORY="kodex/codex-hook-ingress"
KODEX_FLEET_MANAGER_INTERNAL_IMAGE_REPOSITORY="kodex/fleet-manager"
KODEX_FLEET_MANAGER_MIGRATIONS_INTERNAL_IMAGE_REPOSITORY="kodex/fleet-manager-migrations"
KODEX_RUNTIME_MANAGER_INTERNAL_IMAGE_REPOSITORY="kodex/runtime-manager"
KODEX_RUNTIME_MANAGER_MIGRATIONS_INTERNAL_IMAGE_REPOSITORY="kodex/runtime-manager-migrations"
KODEX_PLATFORM_EVENT_LOG_MIGRATIONS_INTERNAL_IMAGE_REPOSITORY="kodex/platform-event-log-migrations"
# Optional version overrides. Keep empty to use services.yaml/spec.versions.
KODEX_ACCESS_MANAGER_VERSION=""
KODEX_PROJECT_CATALOG_VERSION=""
KODEX_PACKAGE_HUB_VERSION=""
KODEX_PROVIDER_HUB_VERSION=""
KODEX_INTEGRATION_GATEWAY_VERSION=""
KODEX_FLEET_MANAGER_VERSION=""
KODEX_RUNTIME_MANAGER_VERSION=""
KODEX_PLATFORM_EVENT_LOG_VERSION=""
# Keep empty to let bootstrap autogenerate from KODEX_INTERNAL_REGISTRY_HOST + per-service repositories.
KODEX_ACCESS_MANAGER_IMAGE=""
KODEX_ACCESS_MANAGER_MIGRATIONS_IMAGE=""
KODEX_PROJECT_CATALOG_IMAGE=""
KODEX_PROJECT_CATALOG_MIGRATIONS_IMAGE=""
KODEX_PACKAGE_HUB_IMAGE=""
KODEX_PACKAGE_HUB_MIGRATIONS_IMAGE=""
KODEX_PROVIDER_HUB_IMAGE=""
KODEX_PROVIDER_HUB_MIGRATIONS_IMAGE=""
KODEX_INTEGRATION_GATEWAY_IMAGE=""
KODEX_CODEX_HOOK_INGRESS_IMAGE=""
KODEX_FLEET_MANAGER_IMAGE=""
KODEX_FLEET_MANAGER_MIGRATIONS_IMAGE=""
KODEX_RUNTIME_MANAGER_IMAGE=""
KODEX_RUNTIME_MANAGER_MIGRATIONS_IMAGE=""
KODEX_PLATFORM_EVENT_LOG_MIGRATIONS_IMAGE=""
KODEX_KANIKO_TIMEOUT="1800s"
KODEX_KANIKO_CACHE_ENABLED="false"
# Optional: if empty, build script uses "${KODEX_INTERNAL_REGISTRY_HOST}/kodex/kaniko-cache".
KODEX_KANIKO_CACHE_REPO=""
KODEX_KANIKO_CACHE_TTL="168h"
KODEX_KANIKO_CACHE_COMPRESSED="false"
KODEX_KANIKO_CACHE_COPY_LAYERS="true"
KODEX_KANIKO_SNAPSHOT_MODE="redo"
KODEX_KANIKO_SINGLE_SNAPSHOT="true"
KODEX_KANIKO_USE_NEW_RUN="true"
KODEX_KANIKO_VERBOSITY="info"
KODEX_KANIKO_CLEANUP="true"
KODEX_KANIKO_CPU_REQUEST="4"
KODEX_KANIKO_MEMORY_REQUEST="8Gi"
KODEX_KANIKO_CPU_LIMIT="16"
KODEX_KANIKO_MEMORY_LIMIT="32Gi"
# Parallel Kaniko jobs for future image build orchestration.
KODEX_KANIKO_MAX_PARALLEL="8"
KODEX_IMAGE_MIRROR_ENABLED="true"
# Parallel mirror jobs for external base images/dependencies.
KODEX_IMAGE_MIRROR_MAX_PARALLEL="8"
KODEX_IMAGE_MIRROR_TOOL_IMAGE="gcr.io/go-containerregistry/crane:debug"
KODEX_IMAGE_MIRROR_PLATFORM="linux/amd64"
KODEX_REGISTRY_SMOKE_SOURCE_IMAGE="busybox:1.36"
KODEX_REGISTRY_CLEANUP_KEEP_TAGS="5"
KODEX_KANIKO_CLONE_IMAGE=""
KODEX_KANIKO_EXECUTOR_IMAGE=""
KODEX_BUSYBOX_IMAGE=""
KODEX_POSTGRES_IMAGE=""
KODEX_OAUTH2_PROXY_IMAGE=""
KODEX_REGISTRY_IMAGE=""
KODEX_KUBECTL_IMAGE=""
KODEX_CODEGEN_CHECK_IMAGE=""
KODEX_INTERNAL_REGISTRY_CPU_REQUEST="100m"
KODEX_INTERNAL_REGISTRY_MEMORY_REQUEST="128Mi"
KODEX_INTERNAL_REGISTRY_CPU_LIMIT="1"
KODEX_INTERNAL_REGISTRY_MEMORY_LIMIT="512Mi"
KODEX_PLATFORM_DEPLOYMENT_REPLICAS="2"
# Default model policy:
# - gpt-5.4 by default.
# - if KODEX_OPENAI_API_KEY is empty, agent runs will require Codex device auth.
KODEX_AGENT_DEFAULT_MODEL="gpt-5.4"
KODEX_AGENT_DEFAULT_REASONING_EFFORT="high"
KODEX_AGENT_DEFAULT_LOCALE="ru"
KODEX_AGENT_BASE_BRANCH="main"
KODEX_PLATFORM_MCP_BASE_URL=""

# Learning mode default for newly created projects.
# Keep "true" to enable educational explanations by default.
# Set empty value to disable by default.
KODEX_LEARNING_MODE_DEFAULT="true"
KODEX_WAIT_ROLLOUT="true"

# Timeouts and retries for slower servers/networks.
KODEX_DNS_WAIT_TIMEOUT="900"
KODEX_DNS_WAIT_INTERVAL="10"
KODEX_BOOTSTRAP_SKIP_DNS_CHECK="false"
KODEX_NODE_DISCOVERY_TIMEOUT="300"
KODEX_NODE_READY_TIMEOUT="1200s"
KODEX_INGRESS_READY_TIMEOUT="1200s"
KODEX_CERT_MANAGER_READY_TIMEOUT="1200s"
KODEX_ROLLOUT_TIMEOUT="1800s"
# Kubelet image GC defaults are too conservative for large disks and allow
# containerd to accumulate hundreds of GiB before pruning. Keep these thresholds
# below your comfortable steady-state usage.
KODEX_K3S_IMAGE_GC_HIGH_THRESHOLD_PERCENT="35"
KODEX_K3S_IMAGE_GC_LOW_THRESHOLD_PERCENT="30"
# Host-level prune complements kubelet GC and removes unused images on a schedule.
KODEX_K3S_IMAGE_PRUNE_TIMER_ENABLED="true"
KODEX_K3S_IMAGE_PRUNE_ONCALENDAR="*-*-* 04:17:00 UTC"

# Optional storage profile for bootstrap.
# For production/single-node k3s, PVC works without Longhorn via the default local-path provisioner.
KODEX_INSTALL_LONGHORN="false"
# For bare-metal/production without cloud LoadBalancer expose ingress directly on host :80/:443.
KODEX_INGRESS_HOST_NETWORK="true"

# Host firewall hardening (recommended).
# When enabled, external inbound access is limited to KODEX_SSH_PORT, 80 and 443.
KODEX_FIREWALL_ENABLED="true"
# Keep equal to TARGET_PORT unless you intentionally expose SSH on another port.
KODEX_SSH_PORT="22"

# NetworkPolicy baseline in Kubernetes (recommended).
# Labels platform/system namespaces and applies baseline restrictions for platform traffic.
KODEX_NETWORK_POLICY_BASELINE="true"
# kodex MCP HTTP port in platform namespace (used by project/agent policy template).
KODEX_PLATFORM_MCP_PORT="8081"

# Allow egress to Kubernetes API server (k3s typically uses nodeIP:6443).
# For single-node production set KODEX_K8S_API_CIDR to the node IP /32.
# If empty, bootstrap will default to TARGET_HOST/32.
KODEX_K8S_API_CIDR=""
KODEX_K8S_API_PORT="6443"

# Optional internal callback base URL for interaction callbacks.
KODEX_INTERACTION_CALLBACK_BASE_URL=""
