# Minimal local-on-server bootstrap env.
#
# Real values in bootstrap/host/config.env are sensitive and must not be
# printed in logs, Issues, PRs or docs. Image versions, default image names,
# deploy inventory and standard artifact names come from services.yaml.
# Go service config owns safe runtime defaults. This file contains local
# install settings and secret/bootstrap seeds only.

# Local operator user created on this server. SSH key is optional for local
# install; when empty/unreadable, authorized_keys provisioning is skipped.
OPERATOR_USER="codex"
OPERATOR_SSH_PUBKEY_PATH="${HOME}/.ssh/id_rsa.pub"

# Kubernetes namespace and DNS preflight. If KODEX_BOOTSTRAP_PUBLIC_HOST is set,
# KODEX_PRODUCTION_DOMAIN must resolve to that host. If it is empty, preflight
# compares the domain with the current host IPv4 addresses. Set
# KODEX_BOOTSTRAP_SKIP_DNS_CHECK=true only for isolated foundation checks.
KODEX_PRODUCTION_NAMESPACE="kodex-prod"
KODEX_PRODUCTION_DOMAIN="platform.example.test"
KODEX_BOOTSTRAP_PUBLIC_HOST=""
KODEX_BOOTSTRAP_SKIP_DNS_CHECK="false"
KODEX_PUBLIC_BASE_URL="https://platform.example.test"
KODEX_LETSENCRYPT_EMAIL=""

# Initial owner/staff bootstrap. Registration stays disabled; the owner email
# becomes a platform admin and can add other users later.
KODEX_BOOTSTRAP_OWNER_EMAIL="owner@example.com"
KODEX_BOOTSTRAP_ALLOWED_EMAILS=""
KODEX_BOOTSTRAP_PLATFORM_ADMIN_EMAILS=""

# Provider/platform credentials that are stored in Kubernetes runtime secrets.
# Leave empty only when the related provider path is intentionally not used yet.
KODEX_GITHUB_REPO=""
KODEX_FIRST_PROJECT_GITHUB_REPO=""
KODEX_GITHUB_PAT=""
KODEX_GIT_BOT_TOKEN=""
KODEX_GIT_BOT_USERNAME="codex-bot"
KODEX_GIT_BOT_MAIL="codex-bot@kodex.local"
KODEX_OPENAI_API_KEY=""
KODEX_CONTEXT7_API_KEY=""
KODEX_GITHUB_OAUTH_CLIENT_ID=""
KODEX_GITHUB_OAUTH_CLIENT_SECRET=""

# Internal registry foundation. Defaults are single-node/k3s friendly.
KODEX_INTERNAL_REGISTRY_PORT="5000"
KODEX_INTERNAL_REGISTRY_HOST="127.0.0.1:5000"
KODEX_INTERNAL_REGISTRY_STORAGE_SIZE="20Gi"
KODEX_INTERNAL_REGISTRY_CPU_REQUEST="100m"
KODEX_INTERNAL_REGISTRY_MEMORY_REQUEST="128Mi"
KODEX_INTERNAL_REGISTRY_CPU_LIMIT="1"
KODEX_INTERNAL_REGISTRY_MEMORY_LIMIT="512Mi"

# Optional image overrides. Leave empty to resolve from services.yaml.
KODEX_REGISTRY_IMAGE=""
KODEX_IMAGE_MIRROR_TOOL_IMAGE=""
KODEX_REGISTRY_SMOKE_SOURCE_IMAGE=""
KODEX_KANIKO_EXECUTOR_IMAGE=""

# Kaniko/mirror smoke tuning. These values affect smoke jobs only.
KODEX_IMAGE_MIRROR_PLATFORM="linux/amd64"
KODEX_IMAGE_MIRROR_CPU_REQUEST="100m"
KODEX_IMAGE_MIRROR_MEMORY_REQUEST="128Mi"
KODEX_IMAGE_MIRROR_CPU_LIMIT="1"
KODEX_IMAGE_MIRROR_MEMORY_LIMIT="512Mi"
KODEX_KANIKO_CACHE_ENABLED="false"
KODEX_KANIKO_SNAPSHOT_MODE="redo"
KODEX_KANIKO_VERBOSITY="info"
KODEX_KANIKO_CPU_REQUEST="1"
KODEX_KANIKO_MEMORY_REQUEST="512Mi"
KODEX_KANIKO_CPU_LIMIT="2"
KODEX_KANIKO_MEMORY_LIMIT="2Gi"

# Host install behavior.
KODEX_NODE_DISCOVERY_TIMEOUT="300"
KODEX_ROLLOUT_TIMEOUT="1800s"
KODEX_K3S_IMAGE_GC_HIGH_THRESHOLD_PERCENT="35"
KODEX_K3S_IMAGE_GC_LOW_THRESHOLD_PERCENT="30"
KODEX_K3S_IMAGE_PRUNE_TIMER_ENABLED="true"
KODEX_K3S_IMAGE_PRUNE_ONCALENDAR="*-*-* 04:17:00 UTC"

# Agent-manager feature switches.
KODEX_AGENT_MANAGER_RUNTIME_JOB_DISPATCH_ENABLED="false"

# Host firewall hardening. Keep this port equal to the actual SSH port used for
# this server, otherwise the install can cut off operator access.
KODEX_FIREWALL_ENABLED="true"
KODEX_SSH_PORT="22"

# Runtime secret seeds. Empty values are generated during install and appended
# to the real local env file without printing secret values.
KODEX_POSTGRES_DB="kodex"
KODEX_POSTGRES_USER="kodex"
KODEX_POSTGRES_PASSWORD=""
KODEX_GITHUB_WEBHOOK_SECRET=""
KODEX_JWT_SIGNING_KEY=""
KODEX_MCP_TOKEN_SIGNING_KEY=""
KODEX_ACCESS_MANAGER_GRPC_AUTH_TOKEN=""
KODEX_PROJECT_CATALOG_GRPC_AUTH_TOKEN=""
KODEX_PACKAGE_HUB_GRPC_AUTH_TOKEN=""
KODEX_PROVIDER_HUB_GRPC_AUTH_TOKEN=""
KODEX_GOVERNANCE_MANAGER_GRPC_AUTH_TOKEN=""
KODEX_INTERACTION_HUB_GRPC_AUTH_TOKEN=""
KODEX_FLEET_MANAGER_GRPC_AUTH_TOKEN=""
KODEX_RUNTIME_MANAGER_GRPC_AUTH_TOKEN=""
KODEX_AGENT_MANAGER_GRPC_AUTH_TOKEN=""
