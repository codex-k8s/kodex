# Target host (Ubuntu 24.04)
TARGET_HOST=""
TARGET_PORT="22"
TARGET_ROOT_USER="root"
TARGET_ROOT_SSH_KEY="${HOME}/.ssh/id_rsa"

# New operator user created on target host
OPERATOR_USER="codex"
OPERATOR_SSH_PUBKEY_PATH="${HOME}/.ssh/id_rsa.pub"

# Platform repository with kodex source (owner/name).
# Bootstrap config and secrets are stored in Kubernetes, not in GitHub variables/secrets.
KODEX_GITHUB_REPO=""
# Optional first project repository (owner/name) for additional webhook + labels setup.
# Bootstrap always configures webhook + labels in KODEX_GITHUB_REPO.
# If empty, only KODEX_GITHUB_REPO is configured (dogfooding mode).
KODEX_FIRST_PROJECT_GITHUB_REPO=""

# External credentials (optional in file; if empty script will ask interactively)
# Required: fine-grained GitHub token used by bootstrap/Kaniko and
# synced into control-plane runtime for repository/project management paths.
# Minimum permissions: repository access required by platform management paths + administration (read/write for webhook/labels in platform repo and optional first project repo).
KODEX_GITHUB_PAT=""
# OpenAI API key for codex-cli API-key auth (optional).
# If empty, Codex will use ChatGPT device auth on first agent run (instructions appear in run logs).
KODEX_OPENAI_API_KEY=""
# Dedicated git transport token for agent-run pods.
KODEX_GIT_BOT_TOKEN=""
KODEX_GIT_BOT_USERNAME="codex-bot"
KODEX_GIT_BOT_MAIL="codex-bot@kodex.local"
# Project DB admin profile used by MCP `database.lifecycle`.
# If any value is empty, bootstrap derives defaults and stores them in Kubernetes secrets:
# - HOST: postgres
# - PORT: 5432
# - USER/PASSWORD: KODEX_POSTGRES_USER / KODEX_POSTGRES_PASSWORD
# - SSLMODE: disable
# - DATABASE: postgres
KODEX_PROJECT_DB_ADMIN_HOST=""
KODEX_PROJECT_DB_ADMIN_PORT=""
KODEX_PROJECT_DB_ADMIN_USER=""
KODEX_PROJECT_DB_ADMIN_PASSWORD=""
KODEX_PROJECT_DB_ADMIN_SSLMODE=""
KODEX_PROJECT_DB_ADMIN_DATABASE=""
# Optional comma-separated allowlist for MCP `database.lifecycle` environment scoping.
# Empty value means app defaults are used (dev,production,prod).
KODEX_PROJECT_DB_LIFECYCLE_ALLOWED_ENVS=""
KODEX_CONTEXT7_API_KEY=""

# Environment-scoped overrides (optional).
#
# For AI slots the platform reads secrets from the shared Kubernetes secret:
# - kodex-runtime-ai (production namespace)
#
# Override rule:
# - Base key: KODEX_<NAME>
# - AI override key: KODEX_AI_<NAME>
# - Production override key: KODEX_PRODUCTION_<NAME>
# - Дополнительный pattern режим: KODEX_<NAME>_AI (см. spec.secretResolution в services.yaml).
#
# Example: to use a different OpenAI key in AI slots set KODEX_AI_OPENAI_API_KEY.
KODEX_AI_OPENAI_API_KEY=""
KODEX_AI_CONTEXT7_API_KEY=""
KODEX_AI_GITHUB_PAT=""
KODEX_AI_GIT_BOT_TOKEN=""
KODEX_GITHUB_OAUTH_CLIENT_ID_AI=""
KODEX_GITHUB_OAUTH_CLIENT_SECRET_AI=""
KODEX_PRODUCTION_GITHUB_OAUTH_CLIENT_ID=""
KODEX_PRODUCTION_GITHUB_OAUTH_CLIENT_SECRET=""

# Staff auth (GitHub OAuth + short-lived JWT).
#
# 1) Create OAuth App at https://github.com/settings/applications/new
# 2) Set:
#    - Homepage URL: https://<KODEX_PRODUCTION_DOMAIN>
#    - Authorization callback URL (shared oauth2-proxy): https://<KODEX_PRODUCTION_DOMAIN>/oauth2/callback
# 3) Fill the Client ID/Secret here.
# Один OAuth App достаточно для production и AI-слотов:
# slot ingress использует centralized auth endpoint через nginx auth-url/auth-signin.
#
# Public base URL is used for OAuth redirect URL generation and must match your domain.
KODEX_PUBLIC_BASE_URL="https://platform.kodex.works"
# Optional: centralized OAuth endpoints used by slot ingresses.
# Empty values are auto-derived from KODEX_PRODUCTION_DOMAIN:
# - https://<KODEX_PRODUCTION_DOMAIN>/oauth2/auth
# - https://<KODEX_PRODUCTION_DOMAIN>/oauth2/start?rd=$scheme://$host$request_uri
KODEX_SHARED_OAUTH2_PROXY_AUTH_URL=""
KODEX_SHARED_OAUTH2_PROXY_SIGNIN_URL=""
# Optional: cookie domain for shared oauth2-proxy session.
# Empty value is auto-derived as ".<KODEX_PRODUCTION_DOMAIN>".
KODEX_OAUTH2_PROXY_COOKIE_DOMAIN=""
# Registration is disabled; first login is allowed only for pre-approved email.
# Owner email becomes a platform admin and can add other users later.
KODEX_BOOTSTRAP_OWNER_EMAIL="owner@example.com"
# Optional: comma-separated list of additional staff emails to pre-provision into DB on startup.
# This avoids {"code":"forbidden","message":"email is not allowed"} on first login.
KODEX_BOOTSTRAP_ALLOWED_EMAILS=""
# Optional: comma-separated list of additional platform admins (owners).
# These emails are created/updated in DB with is_platform_admin=true on startup.
KODEX_BOOTSTRAP_PLATFORM_ADMIN_EMAILS=""
KODEX_GITHUB_OAUTH_CLIENT_ID=""
KODEX_GITHUB_OAUTH_CLIENT_SECRET=""
# Optional: if empty, bootstrap generates a random value.
KODEX_JWT_SIGNING_KEY=""
KODEX_MCP_TOKEN_SIGNING_KEY=""
# Short-lived JWT TTL (e.g. 15m, 30m). Stored in runtime secret as plain text.
KODEX_JWT_TTL="15m"
KODEX_MCP_TOKEN_TTL="24h"
KODEX_RUN_HEAVY_FIELDS_RETENTION_DAYS="7"
KODEX_RUN_AGENT_LOGS_RETENTION_DAYS="7"
# Optional: if empty, bootstrap generates a random value.
# Used for validating GitHub webhook signatures (X-Hub-Signature-256).
KODEX_GITHUB_WEBHOOK_SECRET=""
# Optional override for repository webhook endpoint.
KODEX_GITHUB_WEBHOOK_URL=""
# Comma-separated GitHub webhook events.
KODEX_GITHUB_WEBHOOK_EVENTS="push,pull_request,issues,issue_comment,pull_request_review,pull_request_review_comment"

# Canonical label catalog used for GitHub labels and platform env/config rendering.
# Active in S3 Day1+: full run:* stage catalog + state:* + need:* labels.
KODEX_RUN_INTAKE_LABEL="run:intake"
KODEX_RUN_INTAKE_REVISE_LABEL="run:intake:revise"
KODEX_RUN_VISION_LABEL="run:vision"
KODEX_RUN_VISION_REVISE_LABEL="run:vision:revise"
KODEX_RUN_PRD_LABEL="run:prd"
KODEX_RUN_PRD_REVISE_LABEL="run:prd:revise"
KODEX_RUN_ARCH_LABEL="run:arch"
KODEX_RUN_ARCH_REVISE_LABEL="run:arch:revise"
KODEX_RUN_DESIGN_LABEL="run:design"
KODEX_RUN_DESIGN_REVISE_LABEL="run:design:revise"
KODEX_RUN_PLAN_LABEL="run:plan"
KODEX_RUN_PLAN_REVISE_LABEL="run:plan:revise"
KODEX_RUN_DEV_LABEL="run:dev"
KODEX_RUN_DEV_REVISE_LABEL="run:dev:revise"
KODEX_RUN_DEBUG_LABEL="run:debug"
KODEX_RUN_DOC_AUDIT_LABEL="run:doc-audit"
KODEX_RUN_QA_LABEL="run:qa"
KODEX_RUN_RELEASE_LABEL="run:release"
KODEX_RUN_POSTDEPLOY_LABEL="run:postdeploy"
KODEX_RUN_OPS_LABEL="run:ops"
KODEX_RUN_SELF_IMPROVE_LABEL="run:self-improve"
KODEX_RUN_RETHINK_LABEL="run:rethink"
KODEX_MODE_DISCUSSION_LABEL="mode:discussion"
KODEX_STATE_BLOCKED_LABEL="state:blocked"
KODEX_STATE_IN_REVIEW_LABEL="state:in-review"
KODEX_STATE_APPROVED_LABEL="state:approved"
KODEX_STATE_SUPERSEDED_LABEL="state:superseded"
KODEX_STATE_ABANDONED_LABEL="state:abandoned"
KODEX_NEED_INPUT_LABEL="need:input"
KODEX_NEED_PM_LABEL="need:pm"
KODEX_NEED_SA_LABEL="need:sa"
KODEX_NEED_QA_LABEL="need:qa"
KODEX_NEED_SRE_LABEL="need:sre"
KODEX_NEED_EM_LABEL="need:em"
KODEX_NEED_KM_LABEL="need:km"
KODEX_NEED_REVIEWER_LABEL="need:reviewer"

# Configuration labels (model/reasoning profile for run:dev and run:dev:revise).
KODEX_AI_MODEL_GPT_5_4_LABEL="[ai-model-gpt-5.4]"
KODEX_AI_MODEL_GPT_5_3_CODEX_LABEL="[ai-model-gpt-5.3-codex]"
KODEX_AI_MODEL_GPT_5_3_CODEX_SPARK_LABEL="[ai-model-gpt-5.3-codex-spark]"
KODEX_AI_MODEL_GPT_5_2_CODEX_LABEL="[ai-model-gpt-5.2-codex]"
KODEX_AI_MODEL_GPT_5_1_CODEX_MAX_LABEL="[ai-model-gpt-5.1-codex-max]"
KODEX_AI_MODEL_GPT_5_2_LABEL="[ai-model-gpt-5.2]"
KODEX_AI_MODEL_GPT_5_1_CODEX_MINI_LABEL="[ai-model-gpt-5.1-codex-mini]"
KODEX_AI_REASONING_LOW_LABEL="[ai-reasoning-low]"
KODEX_AI_REASONING_MEDIUM_LABEL="[ai-reasoning-medium]"
KODEX_AI_REASONING_HIGH_LABEL="[ai-reasoning-high]"
KODEX_AI_REASONING_EXTRA_HIGH_LABEL="[ai-reasoning-extra-high]"

# Production settings
KODEX_PRODUCTION_NAMESPACE="kodex-prod"
# Required: must resolve to TARGET_HOST before bootstrap starts.
KODEX_PRODUCTION_DOMAIN="platform.kodex.works"
KODEX_AI_DOMAIN="ai.platform.kodex.works"
# Required for Let's Encrypt account registration.
KODEX_LETSENCRYPT_EMAIL="ops@example.com"
KODEX_LETSENCRYPT_SERVER="https://acme-v02.api.letsencrypt.org/directory"

# Internal registry (no auth by design for MVP).
# Security model for production: registry listens on node loopback (127.0.0.1) only.
# This profile is intended for single-node production.
KODEX_INTERNAL_REGISTRY_SERVICE="kodex-registry"
KODEX_INTERNAL_REGISTRY_PORT="5000"
KODEX_INTERNAL_REGISTRY_STORAGE_SIZE="20Gi"
KODEX_INTERNAL_REGISTRY_HOST="127.0.0.1:5000"
KODEX_API_GATEWAY_INTERNAL_IMAGE_REPOSITORY="kodex/api-gateway"
KODEX_TELEGRAM_INTERACTION_ADAPTER_INTERNAL_IMAGE_REPOSITORY="kodex/telegram-interaction-adapter"
KODEX_CONTROL_PLANE_INTERNAL_IMAGE_REPOSITORY="kodex/control-plane"
KODEX_WORKER_INTERNAL_IMAGE_REPOSITORY="kodex/worker"
KODEX_AGENT_RUNNER_INTERNAL_IMAGE_REPOSITORY="kodex/agent-runner"
KODEX_WEB_CONSOLE_INTERNAL_IMAGE_REPOSITORY="kodex/web-console"
# Keep empty to let bootstrap autogenerate from KODEX_INTERNAL_REGISTRY_HOST + per-service repositories.
KODEX_API_GATEWAY_IMAGE=""
KODEX_TELEGRAM_INTERACTION_ADAPTER_IMAGE=""
KODEX_CONTROL_PLANE_IMAGE=""
KODEX_WORKER_IMAGE=""
KODEX_AGENT_RUNNER_IMAGE=""
KODEX_WEB_CONSOLE_IMAGE=""
KODEX_KANIKO_TIMEOUT="1800s"
KODEX_KANIKO_CACHE_ENABLED="false"
# Optional: if empty, build script uses "${KODEX_INTERNAL_REGISTRY_HOST}/kodex/kaniko-cache".
KODEX_KANIKO_CACHE_REPO=""
KODEX_KANIKO_CACHE_TTL="168h"
KODEX_KANIKO_CACHE_COMPRESSED="false"
KODEX_KANIKO_CACHE_COPY_LAYERS="true"
KODEX_KANIKO_SNAPSHOT_MODE="redo"
KODEX_KANIKO_SINGLE_SNAPSHOT="true"
KODEX_KANIKO_USE_NEW_RUN="true"
KODEX_KANIKO_VERBOSITY="info"
KODEX_KANIKO_CLEANUP="true"
KODEX_KANIKO_CPU_REQUEST="4"
KODEX_KANIKO_MEMORY_REQUEST="8Gi"
KODEX_KANIKO_CPU_LIMIT="16"
KODEX_KANIKO_MEMORY_LIMIT="32Gi"
# Parallel kaniko build jobs inside one runtime-deploy task.
KODEX_KANIKO_MAX_PARALLEL="8"
KODEX_IMAGE_MIRROR_ENABLED="true"
# Parallel mirror jobs for external base images/dependencies.
KODEX_IMAGE_MIRROR_MAX_PARALLEL="8"
KODEX_IMAGE_MIRROR_TOOL_IMAGE="gcr.io/go-containerregistry/crane:debug"
KODEX_IMAGE_MIRROR_PLATFORM="linux/amd64"
KODEX_REGISTRY_CLEANUP_KEEP_TAGS="5"
KODEX_KANIKO_CLONE_IMAGE=""
KODEX_KANIKO_EXECUTOR_IMAGE=""
KODEX_BUSYBOX_IMAGE=""
KODEX_POSTGRES_IMAGE=""
KODEX_OAUTH2_PROXY_IMAGE=""
KODEX_REGISTRY_IMAGE=""
KODEX_KUBECTL_IMAGE=""
KODEX_CODEGEN_CHECK_IMAGE=""
KODEX_PLATFORM_DEPLOYMENT_REPLICAS="2"
# Reconciler workers per control-plane pod (total parallel deploy tasks ~= replicas * workers).
KODEX_RUNTIME_DEPLOY_WORKERS_PER_POD="4"

# Worker defaults (run loop + slots + Kubernetes jobs).
# Keep >=3 in production so one worker stays available when two are blocked by long runtime prepare.
KODEX_WORKER_REPLICAS="3"
KODEX_WORKER_POLL_INTERVAL="5s"
KODEX_WORKER_CLAIM_LIMIT="10"
KODEX_WORKER_RUNNING_CHECK_LIMIT="200"
KODEX_WORKER_SLOTS_PER_PROJECT="2"
KODEX_WORKER_SLOT_LEASE_TTL="10m"
KODEX_WORKER_RUN_LEASE_TTL="45m"
KODEX_WORKER_MISSION_CONTROL_WARMUP_INTERVAL="15m"
KODEX_WORKER_MISSION_CONTROL_WARMUP_PROJECT_LIMIT="20"
KODEX_WORKER_MISSION_CONTROL_PENDING_COMMAND_LIMIT="20"
KODEX_WORKER_MISSION_CONTROL_CLAIM_TTL="2m"
KODEX_WORKER_MISSION_CONTROL_RETRY_MAX_ATTEMPTS="3"
KODEX_WORKER_MISSION_CONTROL_RETRY_BASE_INTERVAL="2s"
KODEX_WORKER_GITHUB_RATE_LIMIT_SWEEP_LIMIT="20"
KODEX_WORKER_K8S_NAMESPACE="kodex-prod"
KODEX_WORKER_JOB_IMAGE=""
KODEX_WORKER_JOB_COMMAND="/usr/local/bin/kodex-agent-runner"
KODEX_WORKER_JOB_TTL_SECONDS="600"
KODEX_WORKER_JOB_BACKOFF_LIMIT="0"
KODEX_WORKER_JOB_ACTIVE_DEADLINE_SECONDS="18000"
KODEX_WORKER_RUN_NAMESPACE_PREFIX="codex-issue"
KODEX_WORKER_RUN_NAMESPACE_CLEANUP="true"
KODEX_WORKER_RUN_SERVICE_ACCOUNT="codex-runner"
KODEX_WORKER_RUN_ROLE_NAME="codex-runner"
KODEX_WORKER_RUN_ROLE_BINDING_NAME="codex-runner"
KODEX_WORKER_RUN_RESOURCE_QUOTA_NAME="codex-run-quota"
KODEX_WORKER_RUN_LIMIT_RANGE_NAME="codex-run-limits"
KODEX_WORKER_RUN_CREDENTIALS_SECRET_NAME="codex-run-credentials"
KODEX_WORKER_RUN_QUOTA_PODS="20"
# Default model policy:
# - gpt-5.4 by default.
# - if KODEX_OPENAI_API_KEY is empty, agent runs will require Codex device auth.
KODEX_AGENT_DEFAULT_MODEL="gpt-5.4"
KODEX_AGENT_DEFAULT_REASONING_EFFORT="high"
KODEX_AGENT_DEFAULT_LOCALE="ru"
KODEX_AGENT_BASE_BRANCH="main"
KODEX_CONTROL_PLANE_GRPC_TARGET="kodex-control-plane.kodex-prod.svc.cluster.local:9090"
KODEX_CONTROL_PLANE_MCP_BASE_URL="http://kodex-control-plane.kodex-prod.svc.cluster.local:8081/mcp"

# Learning mode default for newly created projects.
# Keep "true" to enable educational explanations by default.
# Set empty value to disable by default.
KODEX_LEARNING_MODE_DEFAULT="true"
KODEX_WAIT_ROLLOUT="true"

# Timeouts and retries for slower servers/networks.
KODEX_DNS_WAIT_TIMEOUT="900"
KODEX_DNS_WAIT_INTERVAL="10"
KODEX_NODE_DISCOVERY_TIMEOUT="300"
KODEX_NODE_READY_TIMEOUT="1200s"
KODEX_INGRESS_READY_TIMEOUT="1200s"
KODEX_CERT_MANAGER_READY_TIMEOUT="1200s"
KODEX_ROLLOUT_TIMEOUT="1800s"
# Kubelet image GC defaults are too conservative for large disks and allow
# containerd to accumulate hundreds of GiB before pruning. Keep these thresholds
# below your comfortable steady-state usage.
KODEX_K3S_IMAGE_GC_HIGH_THRESHOLD_PERCENT="35"
KODEX_K3S_IMAGE_GC_LOW_THRESHOLD_PERCENT="30"
# Host-level prune complements kubelet GC and removes unused images on a schedule.
KODEX_K3S_IMAGE_PRUNE_TIMER_ENABLED="true"
KODEX_K3S_IMAGE_PRUNE_ONCALENDAR="*-*-* 04:17:00 UTC"

# Optional storage profile for bootstrap.
# For production/single-node k3s, PVC works without Longhorn via the default local-path provisioner.
KODEX_INSTALL_LONGHORN="false"
# For bare-metal/production without cloud LoadBalancer expose ingress directly on host :80/:443.
KODEX_INGRESS_HOST_NETWORK="true"

# Host firewall hardening (recommended).
# When enabled, external inbound access is limited to KODEX_SSH_PORT, 80 and 443.
KODEX_FIREWALL_ENABLED="true"
# Keep equal to TARGET_PORT unless you intentionally expose SSH on another port.
KODEX_SSH_PORT="22"

# NetworkPolicy baseline in Kubernetes (recommended).
# Labels platform/system namespaces and applies baseline restrictions for platform traffic.
KODEX_NETWORK_POLICY_BASELINE="true"
# kodex MCP HTTP port in platform namespace (used by project/agent policy template).
KODEX_PLATFORM_MCP_PORT="8081"

# Allow egress to Kubernetes API server (k3s typically uses nodeIP:6443).
# For single-node production set KODEX_K8S_API_CIDR to the node IP /32.
# If empty, bootstrap will default to TARGET_HOST/32.
KODEX_K8S_API_CIDR=""
KODEX_K8S_API_PORT="6443"

# Optional Telegram bot for alerts
KODEX_TELEGRAM_BOT_TOKEN=""
KODEX_TELEGRAM_CHAT_ID=""
# Optional internal callback base URL for adapter -> api-gateway interaction callbacks.
# Keep empty to let control-plane fall back to KODEX_PUBLIC_BASE_URL.
KODEX_INTERACTION_CALLBACK_BASE_URL=""
# Optional: explicit GitHub login -> Telegram chat mapping JSON for telegram-interaction-adapter.
KODEX_TELEGRAM_INTERACTION_ADAPTER_BASE_URL=""
KODEX_TELEGRAM_INTERACTION_ADAPTER_BEARER_TOKEN=""
KODEX_TELEGRAM_INTERACTION_ADAPTER_WEBHOOK_SECRET=""
KODEX_TELEGRAM_INTERACTION_ADAPTER_TIMEOUT="10s"
KODEX_TELEGRAM_INTERACTION_ADAPTER_RECIPIENT_BINDINGS_JSON=""
